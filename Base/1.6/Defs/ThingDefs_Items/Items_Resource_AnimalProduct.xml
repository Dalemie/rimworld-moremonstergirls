<Defs>
   <!--================================ Milk ======================================-->
   
  <ThingDef ParentName="OrganicProductBase">
    <defName>MMG_CentaurMilk</defName>
    <label>centaur milk</label>
    <description>Milk from a happy centaur.  Prized for its slight earthy taste.</description>
    <graphicData>
      <texPath>Things/Item/Resource/MMG_CentaurMilk</texPath>
    </graphicData>
    <socialPropernessMatters>true</socialPropernessMatters>
    <statBases>
      <MarketValue>1.9</MarketValue>
      <Mass>0.045</Mass>
      <Nutrition>0.06</Nutrition>
      <FoodPoisonChanceFixedHuman>0</FoodPoisonChanceFixedHuman>
    </statBases>
    <comps>
      <li Class="CompProperties_Rottable">
        <daysToRotStart>14</daysToRotStart>
        <rotDestroys>true</rotDestroys>
      </li>
    </comps>
    <ingestible>
      <preferability>RawTasty</preferability>
      <foodType>AnimalProduct, Fluid</foodType>
      <joy>0.55</joy>
      <joyKind>Gluttonous</joyKind>
    </ingestible>
    <thingCategories>
      <li>AnimalProductRaw</li>
    </thingCategories>
  </ThingDef>
  
