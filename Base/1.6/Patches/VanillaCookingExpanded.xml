				<!-- Monster Girl Cheese -->
				<li Class="PatchOperationAdd"> 
					<success>Always</success>
					<xpath>/Defs</xpath>
					<value>
						<ThingDef ParentName="MealBase">
							<defName>VCE_MonsterGirlCheese</defName>
							<label>monster girl cheese</label>
							<description>A delicious cheese extracted from milk created by monster girl. What a mythical taste!</description>
							<graphicData>
								<texPath>Things/Item/Cheese/MMG_Cheese</texPath>
								<graphicClass>Graphic_StackCount</graphicClass>
							</graphicData>
							<tradeability>Sellable</tradeability>
							<stackLimit>75</stackLimit>
							<statBases>
								<MarketValue>10</MarketValue>
								<Nutrition>0.15</Nutrition>

							</statBases>
							<thingCategories>
								<li>VCE_Cheese</li>
							</thingCategories>
							<ingestible>
								<preferability>MealLavish</preferability>
								<ingestEffect>EatMeat</ingestEffect>
								<ingestSound>Meal_Eat</ingestSound>
								<maxNumToIngestAtOnce>7</maxNumToIngestAtOnce>


							</ingestible>
							<comps>
								<li Class="CompProperties_Rottable">
									<daysToRotStart>80</daysToRotStart>
									<rotDestroys>true</rotDestroys>
								</li>
								<li>
									<compClass>CompQuality</compClass>
								</li>
								<li Class="VEF.Cooking.CompProperties_StackByQuality"/>
								<li Class="VEF.Cooking.CompProperties_IngestedThoughtFromQuality">
									<ingestedThought>VCE_AteCheese</ingestedThought>
								</li>
							</comps>
						</ThingDef>
					</value>
				</li>

				<!-- Centaur Milk -->
				<li Class="PatchOperationAdd"> 
					<success>Always</success>
					<xpath>/Defs</xpath>
					<value>
						<PipeSystem.ProcessDef>
							<defName>VCE_CentaurMilkIntoCheese</defName>
							<label>Centaur Milk into cheese</label>
							<description>Turns 50 centaur milk into 25 cheese.</description>
							<labelOverride>Turn 50 centaur milk into 25 cheese.</labelOverride>
							<priorityInBillList>4</priorityInBillList>
							<useIngredients>true</useIngredients>
							<spawnOnInteractionCell>true</spawnOnInteractionCell>
							<ingredients>
								<li>
									<thing>MMG_CentaurMilk</thing>
									<countNeeded>50</countNeeded>
								</li>
							</ingredients>
							<ticksQuality>
								<li>600000</li>
								<li>900000</li>
								<li>1500000</li>
								<li>2100000</li>
								<li>2400000</li>
								<li>2700000</li>
								<li>4500000</li>
							</ticksQuality>
							<results>
								<li>
									<thing>VCE_MonsterGirlCheese</thing>
									<count>25</count>
								</li>
							</results>
							<stopAtQuality>true</stopAtQuality>
							<allowExtractAtCurrentQuality>true</allowExtractAtCurrentQuality>
							<autoExtract>false</autoExtract>
						</PipeSystem.ProcessDef>

